# INFRASTRUCTURE CONFIG + SECRETS
# [Задаются окружением: ОС, K8s, Docker, Vercel Dashboard и т.п.]

# HTTP-порт приложения
PORT=4000

# Базовый URL приложения — используется в ссылках подтверждения email
MAIN_URL=http://localhost:4000

# Имя базы данных MongoDB
DB_NAME=express-incubator

# Хост MongoDB (локального или облачного)
MONGO_URI=mongodb://127.0.0.1:27017/?maxPoolSize=20&w=majority

# Секрет для подписи access JWT
ACCESS_JWT_SECRET=

# Секрет для подписи refresh JWT
REFRESH_JWT_SECRET=

# SMTP-логин для отправки email
NODEMAILER_USER_TRANSPORT=

# SMTP-пароль для отправки email
NODEMAILER_PASSWORD_TRANSPORT=